# Copy to .env and fill in values:
#   cp examples/.env.example examples/.env
# Or create .env in project root; the script checks both.

# Required for x402/A2A demo
PRIVATE_KEY=0x...
RPC_URL=https://base-sepolia.drpc.org

# Chain (default 84532 = Base Sepolia, same as TS demo)
# CHAIN_ID=84532

# Flow 2/3: agent IDs (defaults match TS demo). loadAgent() needs IPFS configured to fetch registration.
# AGENT_ID_PURE_A2A=84532:1298
# AGENT_ID_A2A_X402=84532:1301

# Optional: x402 flow 1 target (defaults to https://httpbin.org/get)
# X402_DEMO_URL=https://twitter.x402.agentbox.fyi/search?q=from:elonmusk+AI&type=Latest&limit=5

# Optional: multichain (mainnet RPC for payments on other chains)
# BASE_MAINNET_RPC_URL=https://base.drpc.org
# OVERRIDE_RPC_URLS={"1":"https://eth.llamarpc.com","8453":"https://mainnet.base.org"}
